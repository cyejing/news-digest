{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tech Digest Configuration Schema",
  "version": "3.1.0",
  "definitions": {
    "apiSource": {
      "type": "object",
      "required": ["id", "name", "enabled", "topic", "priority"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "topic": {
          "type": "string"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["id", "type", "name", "enabled", "priority", "topic"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the source"
        },
        "type": {
          "type": "string",
          "enum": ["rss", "twitter", "github", "reddit"],
          "description": "Source type"
        },
        "name": {
          "type": "string",
          "description": "Human-readable source name"
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether this source is active"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Priority hint from 1-10. In practice, keep most sources near 3, use 4 for clearly authoritative sources, and reserve 5+ for a very small number of top-tier primary sources."
        },
        "topic": {
          "type": "string",
          "description": "Single primary topic ID for this source"
        },
        "note": {
          "type": "string",
          "description": "Optional description or note"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "RSS feed URL (required for type=rss)"
        },
        "handle": {
          "type": "string",
          "description": "Twitter handle without @ (required for type=twitter)"
        },
        "repo": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9._-]+/[a-zA-Z0-9._-]+$",
          "description": "GitHub repository in owner/repo format (required for type=github)"
        },
        "subreddit": {
          "type": "string",
          "description": "Subreddit name without r/ prefix (required for type=reddit)"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "rss" } }
          },
          "then": {
            "required": ["url"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "twitter" } }
          },
          "then": {
            "required": ["handle"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "github" } }
          },
          "then": {
            "required": ["repo"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "reddit" } }
          },
          "then": {
            "required": ["subreddit"]
          }
        }
      ]
    },
    "topic": {
      "type": "object",
      "required": ["id", "emoji", "label", "description", "search", "display"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique topic identifier"
        },
        "emoji": {
          "type": "string",
          "description": "Topic emoji for display"
        },
        "label": {
          "type": "string",
          "description": "Topic display name"
        },
        "description": {
          "type": "string",
          "description": "Topic description"
        },
        "classification": {
          "type": "object",
          "properties": {
            "definition": {
              "type": "string"
            },
            "when_to_use": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "when_not_to_use": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "examples": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "search": {
          "type": "object",
          "required": ["queries"],
          "properties": {
            "queries": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Search queries for web search"
            },
            "exclude": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Keywords to exclude"
            },
            "github_queries": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Preferred query list for GitHub trending search"
            }
          }
        },
        "display": {
          "type": "object",
          "required": ["max_items"],
          "properties": {
            "max_items": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum items to show for this topic"
            },
            "style": {
              "type": "string",
              "enum": ["compact", "detailed"],
              "description": "Display style"
            }
          }
        }
      }
    },
    "topicRules": {
      "type": "object",
      "properties": {
        "topic_priority": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Single-topic resolution priority from highest to lowest"
        },
        "legacy_topic_map": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Legacy topic IDs mapped into the current taxonomy"
        },
        "source_rules": {
          "type": "object",
          "properties": {
            "v2ex": {
              "type": "object",
              "properties": {
                "node_topic_map": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "keyword_map": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "sourceGroup": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/source"
      }
    },
    "apiSourceGroup": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/apiSource"
      }
    }
  },
  "type": "object",
  "properties": {
    "sources": {
      "type": "object",
      "required": ["rss", "twitter", "github", "reddit"],
      "additionalProperties": false,
      "properties": {
        "rss": {
          "$ref": "#/definitions/sourceGroup"
        },
        "twitter": {
          "$ref": "#/definitions/sourceGroup"
        },
        "github": {
          "$ref": "#/definitions/sourceGroup"
        },
        "reddit": {
          "$ref": "#/definitions/sourceGroup"
        }
      }
    },
    "topics": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/topic"
      }
    },
    "topic_rules": {
      "$ref": "#/definitions/topicRules"
    },
    "api_sources": {
      "type": "object",
      "required": ["sources"],
      "properties": {
        "sources": {
          "$ref": "#/definitions/apiSourceGroup"
        }
      }
    }
  }
}
